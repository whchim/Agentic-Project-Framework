# =========================
# Basic Environment
# =========================
APP_NAME=example-project
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# =========================
# Database
# =========================
DATABASE_URL=postgresql://user:password@localhost:5432/example_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=example_db
DB_USER=user
DB_PASSWORD=password

# =========================
# Cache / Queue
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# Auth
# =========================
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=60
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# =========================
# AI / Model Settings
# =========================
AI_PROVIDER=custom
AI_MODEL_NAME=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_SECONDS=30

# =========================
# Observability
# =========================
LOG_LEVEL=INFO
TRACE_ENABLED=false
REQUEST_ID_HEADER=X-Request-Id

# =========================
# Feature Flags
# =========================
FEATURE_X_ENABLED=false
FEATURE_Y_ENABLED=false

# =========================
# Security
# =========================
ENABLE_RATE_LIMIT=true
ENABLE_CSRF_PROTECTION=false
ENABLE_SENSITIVE_LOG_REDACTION=true